pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/megha527/devops-free-tier-cicd.git'
            }
        }

        stage('Validate') {
            steps {
                echo 'Code fetched successfully'
                sh 'ls -l'
            }
        }
    }
}
